{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin-dashboard.html"
    },
    {
      "source": "/frontend/admin-dashboard.html",
      "destination": "/admin-dashboard.html"
    },
    {
      "source": "/cv",
      "destination": "/cv-builder.html"
    },
    {
      "source": "/css/(.*)",
      "destination": "/frontend/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/frontend/js/$1"
    }
  ]
}
