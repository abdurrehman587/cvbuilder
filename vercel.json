{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/auth",
      "dest": "/frontend/auth.html"
    },
    {
      "src": "/admin",
      "dest": "/frontend/admin-dashboard.html"
    },
    {
      "src": "/shopkeeper",
      "dest": "/frontend/shopkeeper-dashboard.html"
    },
    {
      "src": "/email-confirmation",
      "dest": "/frontend/email-confirmation.html"
    },
    {
      "src": "/fix-user-role",
      "dest": "/frontend/fix-user-role.html"
    },
    {
      "src": "/create-admin-simple",
      "dest": "/frontend/create-admin-simple.html"
    },
    {
      "src": "/create-admin-proper",
      "dest": "/frontend/create-admin-proper.html"
    },
    {
      "src": "/fix-admin-user",
      "dest": "/frontend/fix-admin-user.html"
    },
    {
      "src": "/debug-auth-method",
      "dest": "/frontend/debug-auth-method.html"
    },
    {
      "src": "/create-user-cvs-table",
      "dest": "/frontend/create-user-cvs-table.html"
    },
    {
      "src": "/debug-cv-save",
      "dest": "/frontend/debug-cv-save.html"
    },
    {
      "src": "/debug-user-cvs-table",
      "dest": "/frontend/debug-user-cvs-table.html"
    },
    {
      "src": "/fix-user-cvs-table",
      "dest": "/frontend/fix-user-cvs-table.html"
    },
    {
      "src": "/simple-user-cvs-test",
      "dest": "/frontend/simple-user-cvs-test.html"
    },
    {
      "src": "/",
      "dest": "/frontend/auth.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}